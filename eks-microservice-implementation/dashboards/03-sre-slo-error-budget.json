        "w": 6,
        "x": 6,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "0.999",
          "legendFormat": "SLO target",
          "refId": "A"
        }
      ]
    },
